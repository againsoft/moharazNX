# MoharazNX API — PostgreSQL (AgainERP ADR-001 / TECHNOLOGY_CONSTITUTION)
# Local DB: docker compose up -d  (from repo root)
# Railway: add PostgreSQL plugin — DATABASE_URL is injected automatically

DATABASE_URL=postgresql+psycopg://moharaznx:moharaznx@127.0.0.1:5433/moharaznx

# API
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# CORS — Next.js dev + production UI (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app

# App
APP_NAME=MoharazNX API
APP_ENV=development
APP_DEBUG=true

# OpenAI — placeholder until real provider wiring (AgainERP pattern). Put key in local .env only.
OPENAI_API_KEY=

# Cloudflare OAuth (production — use Railway public API URL)
# CLOUDFLARE_OAUTH_CLIENT_ID=
# CLOUDFLARE_OAUTH_CLIENT_SECRET=
# CLOUDFLARE_OAUTH_REDIRECT_URI=https://your-api.up.railway.app/api/v1/plugins/cloudflare/oauth/callback
# CLOUDFLARE_OAUTH_SUCCESS_REDIRECT=https://your-app.vercel.app/settings/plugins/cloudflare
